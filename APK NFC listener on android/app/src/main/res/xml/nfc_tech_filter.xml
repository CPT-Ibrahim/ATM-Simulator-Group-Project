<?xml version="1.0" encoding="utf-8"?>
<!--
    NFC technology filters — covers the most common card types:
    - NfcA  : Mifare Classic, Mifare Ultralight (most key fobs & access cards)
    - NfcB  : Some bank cards and ID cards
    - IsoDep: ISO 14443-4 cards (bank cards, modern transit cards)
    - NfcF  : FeliCa (common in Japan)
    - NfcV  : ISO 15693 vicinity cards
-->
